# Copy to .env.local and fill in

# ── Posting ──────────────────────────────────────────────
# "mock" (works out of the box), "ayrshare" or "blotato"
POSTING_PROVIDER=mock
# Blotato API key (blotato.com -> Settings -> API), needed when POSTING_PROVIDER=blotato
BLOTATO_API_KEY=
# Ayrshare API key (app.ayrshare.com) — 28-day free trial, no card needed
AYRSHARE_API_KEY=

# ── AI content (scripts, ideas, SEO, captions) ───────────
# console.anthropic.com — without it, template fallbacks are used
ANTHROPIC_API_KEY=

# ── Video generation ─────────────────────────────────────
# Voice-over: platform.openai.com — without it, videos render with a silent track
OPENAI_API_KEY=
# Stock footage: free key from pexels.com/api — without it, animated gradient slides are used
PEXELS_API_KEY=
# Optional: YouTube Data API key for niche trending research (console.cloud.google.com)
YOUTUBE_API_KEY=

# Product Ads: AI video generation via fal.ai (fal.ai/dashboard/keys, pay-per-use)
# Without it, Product Ads renders a free slideshow mock.
FAL_KEY=
# Optional override of the fal.ai model used for ads
FAL_MODEL=

# ── App ──────────────────────────────────────────────────
# Public URL (needed so posting providers can fetch your rendered videos)
APP_URL=http://localhost:3000
# Protects /api/worker in production
WORKER_SECRET=

# ── Payments (Paddle / Lemon Squeezy / Flutterwave links) ─
# When set, pricing-page buttons link straight to checkout
PAYMENT_LINK_PUBLISHER=
PAYMENT_LINK_CREATOR=
PAYMENT_LINK_AUTOPILOT=
PAYMENT_LINK_STUDIO=
